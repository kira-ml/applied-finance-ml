# --- Project Specific: Data ---
# Ignore all raw CSVs (protects sensitive financial data)
data/raw_transactions.csv
data/raw/*.csv

# Ignore processed intermediate files (regeneratable)
data/processed/*
!data/processed/.gitkeep

# --- Project Specific: Artifacts ---
# Ignore trained models and binaries (large, reproducible via pipeline)
artifacts/*
!artifacts/deploy_ready/.gitkeep

# --- Logs & Temp ---
*.log
tmp/
temp/